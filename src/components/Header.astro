---
import "../styles/global.css";
import HeaderLink from "./HeaderLink.astro";
---

<header class="bg-white px-4 py-4">
  <nav
    class="flex flex-col sm:flex-row items-center justify-between gap-2 sm:gap-0 relative px-2"
  >
    <h2 class="text-sm m-0">
      <a href="/">
        <img
          src="/src/assets/rgif.gif"
          alt="Logo"
          class="h-12 w-12 sm:h-20 sm:w-20"
        />
      </a>
    </h2>
    <div class="flex gap-2 sm:gap-4 text-xs sm:text-sm">
      <HeaderLink
        href="/"
        class="py-4 px-2 text-black border-b-4 border-transparent hover:border-gray-300 font-jetmono"
      >
        Home
      </HeaderLink>
      <HeaderLink
        href="/about"
        class="py-4 px-2 text-black border-b-4 border-transparent hover:border-gray-300"
      >
        About
      </HeaderLink>
      <HeaderLink
        href="/blog"
        class="py-4 px-2 text-black border-b-4 border-transparent hover:border-gray-300"
      >
        Blog
      </HeaderLink>
      <HeaderLink
        href="/project"
        class="py-4 px-2 text-black border-b-4 border-transparent hover:border-gray-300"
      >
        Projects
      </HeaderLink>
    </div>
  </nav>
</header>
