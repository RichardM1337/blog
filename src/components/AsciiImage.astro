---
const { src, alt = "" } = Astro.props;
---

<div class="ascii-wrapper w-full overflow-x-auto">
  <pre
    class="ascii max-w-full overflow-hidden text-[4px] sm:text-[6px] md:text-[7px] lg:text-[8px] leading-1.5 whitespace-pre">
  </pre>
  <img class="hidden img" src={src} alt={alt} />
  <canvas class="hidden"></canvas>
</div>

<script>
  function initAscii(wrapper) {
    const img = wrapper.querySelector(".img");
    const pre = wrapper.querySelector(".ascii");
    const canvas = wrapper.querySelector("canvas");
    const ctx = canvas.getContext("2d");

    const maxWidth = 180;
    const run = () => {
      // 👉 NEW: control height here
      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      const width = window.innerWidth;

      let heightFactor = 1.0;

      if (width >= 1024) heightFactor = 1.6;
      else if (width >= 768) heightFactor = 1.3;
      else heightFactor = 1.0;

      const aspectRatio = img.naturalHeight / img.naturalWidth;

      const cols = Math.min(img.naturalWidth, maxWidth);
      const rows = Math.floor(cols * aspectRatio * 0.55 * heightFactor);

      canvas.width = cols;
      canvas.height = rows;

      ctx.drawImage(img, 0, 0, cols, rows);

      const pixels = ctx.getImageData(0, 0, cols, rows).data;

      const chars = "@#S%?*+;:,.";
      let ascii = "";

      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const i = (y * cols + x) * 4;

          const r = pixels[i];
          const g = pixels[i + 1];
          const b = pixels[i + 2];

          const brightness = (r + g + b) / 3;
          ascii += chars[Math.floor((brightness / 255) * (chars.length - 1))];
        }
        ascii += "\n";
      }

      pre.textContent = ascii;
    };

    if (img.complete) run();
    else img.onload = run;
  }

  // ✅ run for ALL instances (safe + simple)
  document.querySelectorAll(".ascii-wrapper").forEach(initAscii);
</script>

<style>
  .ascii {
    font-family: monospace;
    white-space: pre;
  }
</style>
