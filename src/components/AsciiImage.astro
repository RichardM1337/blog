---
const { src, alt = "" } = Astro.props;
---

<div class="ascii-wrapper w-full overflow-x-auto">
  <pre
    class="ascii max-w-full overflow-hidden text-[4px] sm:text-[6px] md:text-[7px] lg:text-[8px] leading-1.5 whitespace-pre">
  </pre>
  <img class="hidden img" src={src} alt={alt} />
  <canvas class="hidden"></canvas>
</div>

<script>
  function initAscii(wrapper) {
    const img = wrapper.querySelector(".img");
    const pre = wrapper.querySelector(".ascii");
    const canvas = wrapper.querySelector("canvas");
    const ctx = canvas.getContext("2d");

    const chars = "@#S%?*+;:,.";
    let resizeTimeout;

    const run = () => {
      if (!img.naturalWidth) return;

      const aspectRatio = img.naturalHeight / img.naturalWidth;
      const charAspect = 0.9;

      const targetRows = 100; // 🔥 uniform height for all images
      let rows = targetRows;

      let cols = Math.floor(rows / (aspectRatio * charAspect));

      // optional clamp so super-wide images don’t explode
      cols = Math.max(60, Math.min(cols, 200));

      canvas.width = cols;
      canvas.height = rows;

      ctx.drawImage(img, 0, 0, cols, rows);

      const pixels = ctx.getImageData(0, 0, cols, rows).data;

      let ascii = "";

      for (let y = 0; y < rows; y++) {
        let row = "";
        for (let x = 0; x < cols; x++) {
          const i = (y * cols + x) * 4;

          const r = pixels[i];
          const g = pixels[i + 1];
          const b = pixels[i + 2];

          const brightness = (r + g + b) / 3;
          const charIndex = Math.floor((brightness / 255) * (chars.length - 1));

          row += chars[charIndex];
        }
        ascii += row + "\n";
      }

      pre.textContent = ascii;
    };
    const observer = new ResizeObserver(() => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(run, 100);
    });

    observer.observe(wrapper);

    if (img.complete) run();
    else img.onload = run;
  }

  document.querySelectorAll(".ascii-wrapper").forEach(initAscii);
</script>

<style>
  .ascii {
    font-family: monospace;
    white-space: pre;
  }
</style>
