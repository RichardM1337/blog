---
import "../styles/global.css";
const today = new Date();
---

<footer class="text-center px-4 pt-8 pb-24 bg-no-repeat">
  <p>
    &copy; {today.getFullYear()} All Rights Reserved
  </p>

  <div class="flex justify-center gap-4 mt-4">
    <a
      href="https://github.com/RichardM1337"
      target="_blank"
      class="underline"
      rel="noopener noreferrer"
    >
      GitHub
    </a>
  </div>
  <div class="flex justify-center items-center gap-6 mt-6">
    <a
      href="https://vuejs.org/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Vue Docs"
      class="flex items-center justify-center"
    >
      <img
        alt="Vue"
        src="/src/assets/languages/vue.png"
        class="w-20 h-20 object-contain"
      />
    </a>
    <a
      href="https://www.typescriptlang.org/docs/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="TypeScript Docs"
      class="flex items-center justify-center"
    >
      <img
        alt="TypeScript"
        src="/src/assets/languages/ts.png"
        class="w-20 h-20 object-contain"
      />
    </a>
    <a
      href="https://www.mongodb.com/docs/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="MongoDB Docs"
      class="flex items-center justify-center"
    >
      <img
        alt="MongoDB"
        src="/src/assets/languages/mdb.png"
        class="w-20 h-20 object-contain"
      />
    </a>
    <a
      href="https://docs.djangoproject.com/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Django Docs"
      class="flex items-center justify-center"
    >
      <img
        alt="Django"
        src="/src/assets/languages/dj.png"
        class="w-20 h-20 object-contain"
      />
    </a>
  </div>
</footer>
